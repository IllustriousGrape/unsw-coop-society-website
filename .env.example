# Supabase — copy this file to .env.local and fill in values from your
# Supabase project dashboard (Settings → API). The site runs with built-in
# placeholder content when these are not set, so local development works
# without a Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Required for the contact form to store messages and for
# admin operations. NEVER expose this to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL, used for SEO metadata and sitemaps.
# e.g. https://unswcoopsoc.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
